# Kie.ai API
KIE_API_KEY=your_kie_api_key_here
KIE_API_BASE=https://api.kie.ai
KIE_UPLOAD_BASE=https://kieai.redpandaai.co

# App settings
APP_HOST=0.0.0.0
APP_PORT=8420
DATABASE_URL=sqlite+aiosqlite:///./data/studio.db

# Asset storage (mount this in Docker)
ASSET_DIR=/app/assets

# Callback URL (your TrueNAS IP/domain for kie.ai to hit)
# Leave empty to use polling instead of callbacks
CALLBACK_BASE_URL=

# Polling interval in seconds for checking generation status
POLL_INTERVAL=15

# Default image model
DEFAULT_IMAGE_MODEL=nano-banana-pro
# DEFAULT_IMAGE_MODEL=nano-banana-2

# Default video model
DEFAULT_VIDEO_MODEL=veo3_fast
# DEFAULT_VIDEO_MODEL=veo3
